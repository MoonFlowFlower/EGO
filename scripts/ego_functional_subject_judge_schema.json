{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["verdict", "scores", "reasons", "missing_evidence", "follow_up_issues", "claim_ceiling"],
  "additionalProperties": false,
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["pass", "partial", "fail"]
    },
    "scores": {
      "type": "object",
      "required": [
        "continuity",
        "independent_preference",
        "bounded_initiative",
        "feedback_plasticity",
        "gate_integrity",
        "traceability",
        "user_experience"
      ],
      "additionalProperties": false,
      "properties": {
        "continuity": {"type": "integer", "minimum": 1, "maximum": 5},
        "independent_preference": {"type": "integer", "minimum": 1, "maximum": 5},
        "bounded_initiative": {"type": "integer", "minimum": 1, "maximum": 5},
        "feedback_plasticity": {"type": "integer", "minimum": 1, "maximum": 5},
        "gate_integrity": {"type": "integer", "minimum": 1, "maximum": 5},
        "traceability": {"type": "integer", "minimum": 1, "maximum": 5},
        "user_experience": {"type": "integer", "minimum": 1, "maximum": 5}
      }
    },
    "reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "missing_evidence": {
      "type": "array",
      "items": {"type": "string"}
    },
    "follow_up_issues": {
      "type": "array",
      "items": {"type": "string"}
    },
    "claim_ceiling": {
      "type": "string"
    }
  }
}
